<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ═══════════════════════════════════════
         HEADER
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#0D0D0D"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp">

        <!-- Línea dorada izquierda -->
        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="#C8A96A"
            android:layout_marginEnd="16dp"/>

        <!-- Botón volver -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_dark"
            android:gravity="center"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <!-- Título -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Mis Pedidos"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Espaciador para centrar título -->
        <View
            android:layout_width="36dp"
            android:layout_height="36dp"/>

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         INFO BAR
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 pedidos realizados"
            android:textColor="#888888"
            android:textSize="12sp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="#C8A96A"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Error banner -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF3F3"
        android:gravity="center"
        android:padding="12dp"
        android:text="Error al cargar pedidos"
        android:textColor="#E53935"
        android:textSize="13sp"
        android:visibility="gone"/>

    <!-- ═══════════════════════════════════════
         CONTENIDO
    ═══════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Lista de pedidos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPedidos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <!-- Estado vacío -->
        <LinearLayout
            android:id="@+id/layoutVacio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="52sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin pedidos aún"
                android:textColor="#0D0D0D"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explora el catálogo y realiza\ntu primera compra"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:id="@+id/btnIrCatalogo"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/bg_gold_button"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:text="VER GALERÍA"
                android:textColor="#0D0D0D"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
