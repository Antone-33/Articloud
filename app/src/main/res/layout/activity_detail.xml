<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- ===== SCROLL CONTENT ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="90dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== IMAGEN GRANDE + BOTONES FLOTANTES ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <ImageView
                    android:id="@+id/imgDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#1A1A1A" />

                <!-- Botón atrás -->
                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle_dark"
                    android:gravity="center"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

                <!-- Botón compartir -->
                <TextView
                    android:id="@+id/btnShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle_dark"
                    android:gravity="center"
                    android:text="⬆"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <!-- Badge sobre imagen -->
                <TextView
                    android:id="@+id/txtBadgeDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- ===== INFO PRINCIPAL ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Categoría · Técnica · Tamaño -->
                <TextView
                    android:id="@+id/txtMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAISAJE · 90X110CM · ACUARELA"
                    android:textColor="#C8A96A"
                    android:textSize="11sp"
                    android:letterSpacing="0.08" />

                <!-- Nombre -->
                <TextView
                    android:id="@+id/txtNameDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Ocean Whisper"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Artista -->
                <TextView
                    android:id="@+id/txtArtistDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="por Leo Marín"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <!-- Precio + Rating -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtPriceDetail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="S/ 1,450"
                        android:textColor="#C8A96A"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="#C8A96A"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/txtRatingDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="4.6"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/txtReviewsDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="(29)"
                        android:textColor="#666666"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Tags: Tamaño · Técnica · Año · Certificado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tagSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:textColor="#CCCCCC"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tagTechnique"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:textColor="#CCCCCC"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tagYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:textColor="#CCCCCC"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_gold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="✓ Certificado"
                        android:textColor="#C8A96A"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Envío gratis -->
                <LinearLayout
                    android:id="@+id/layoutFreeShipping"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚚"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Envío gratis"
                        android:textColor="#4CAF50"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ===== TABS: Descripción / Detalles / Reseñas ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/tabDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="24dp"
                    android:paddingBottom="8dp"
                    android:text="Descripción"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="24dp"
                    android:paddingBottom="8dp"
                    android:text="Detalles"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tabReviews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="8dp"
                    android:text="Reseñas"
                    android:textColor="#666666"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Línea divisora -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="#2A2A2A" />

            <!-- ===== CONTENIDO TABS ===== -->

            <!-- Tab Descripción -->
            <LinearLayout
                android:id="@+id/contentDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.5"
                    android:text="Descripción de la obra..."
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Tab Detalles -->
            <LinearLayout
                android:id="@+id/contentDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Técnica" android:textColor="#888888" android:textSize="13sp"/>
                    <TextView android:id="@+id/detailTechnique" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="13sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dimensiones" android:textColor="#888888" android:textSize="13sp"/>
                    <TextView android:id="@+id/detailSize" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="13sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Año" android:textColor="#888888" android:textSize="13sp"/>
                    <TextView android:id="@+id/detailYear" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="13sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Categoría" android:textColor="#888888" android:textSize="13sp"/>
                    <TextView android:id="@+id/detailCategory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="13sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Envío" android:textColor="#888888" android:textSize="13sp"/>
                    <TextView android:id="@+id/detailShipping" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Tab Reseñas -->
            <LinearLayout
                android:id="@+id/contentReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★★★★★"
                    android:textColor="#C8A96A"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/txtReviewScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtReviewCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#888888"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTÓN FIJO ABAJO ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#0D0D0D"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnAddCart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bd_gold_button"
            android:text="🔒 Inicia sesión para comprar"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>