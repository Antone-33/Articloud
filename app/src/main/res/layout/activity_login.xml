<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════════════════════════════════
             HEADER — franja oscura superior
        ═══════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#0D0D0D">

            <!-- Línea decorativa dorada izquierda -->
            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="#C8A96A" />

            <!-- Contenido centrado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="32dp">

                <!-- Logo -->
                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="16dp" />

                <!-- Línea decorativa -->
                <View
                    android:layout_width="32dp"
                    android:layout_height="1dp"
                    android:background="#C8A96A"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ARTICLOUD"
                    android:textColor="#C8A96A"
                    android:textSize="11sp"
                    android:letterSpacing="0.3"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido de vuelta"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accede a tu colección de arte"
                    android:textColor="#888888"
                    android:textSize="13sp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- ═══════════════════════════════════════
             FORMULARIO
        ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="32dp">

            <!-- ── CORREO ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORREO ELECTRÓNICO"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input_register"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉"
                    android:textColor="#AAAAAA"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:hint="tu@correo.com"
                    android:inputType="textEmailAddress"
                    android:textColor="#0D0D0D"
                    android:textColorHint="#CCCCCC"
                    android:textSize="15sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvErrorEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa un correo válido"
                android:textColor="#E53935"
                android:textSize="11sp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- ── CONTRASEÑA ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTRASEÑA"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input_register"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:textColor="#0D0D0D"
                    android:textColorHint="#CCCCCC"
                    android:textSize="15sp" />

                <!-- Ojo para mostrar/ocultar contraseña -->
                <ImageButton
                    android:id="@+id/btnTogglePass"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="#AAAAAA"
                    tools:ignore="SpeakableTextPresentCheck" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvErrorPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa tu contraseña"
                android:textColor="#E53935"
                android:textSize="11sp"
                android:visibility="gone"/>

            <!-- Restablecer contraseña -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="Restablecer contraseña"
                android:textColor="#C8A96A"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp"/>

            <!-- ── DIVIDER ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="24dp"/>

            <!-- ── ERROR GENERAL ── -->
            <TextView
                android:id="@+id/tvErrorGeneral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF3F3"
                android:padding="12dp"
                android:text="Credenciales incorrectas"
                android:textColor="#E53935"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- ── PROGRESS BAR ── -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="#C8A96A"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- ── BOTÓN INGRESAR ── -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_gold_button"
                android:text="INGRESAR"
                android:textColor="#0D0D0D"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="24dp"/>

            <!-- ── DIVISOR "o continúa con" ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E8E8E8"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:text="o continúa con"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E8E8E8"/>

            </LinearLayout>

            <!-- ── BOTONES SOCIALES ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/btnGoogle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_input_register"
                    android:text="Google"
                    android:textColor="#0D0D0D"
                    android:textSize="12sp"/>

                <Button
                    android:id="@+id/btnFacebook"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@drawable/bg_input_register"
                    android:text="Facebook"
                    android:textColor="#0D0D0D"
                    android:textSize="12sp"/>

                <Button
                    android:id="@+id/btnApple"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_register"
                    android:text="Apple"
                    android:textColor="#0D0D0D"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- ── IR AL REGISTRO ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿No tienes cuenta? "
                    android:textColor="#888888"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/txtRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Regístrate"
                    android:textColor="#C8A96A"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ── TÉRMINOS ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Arte exclusivo para coleccionistas"
                android:textColor="#CCCCCC"
                android:textSize="11sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
