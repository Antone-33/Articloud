<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Articloud" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Barra superior negra -->
        <item name="android:statusBarColor">@color/black_main</item>

        <!-- Iconos blancos en la barra -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

    </style>

    <style name="Theme.Articloud" parent="Base.Theme.Articloud" />

    <style name="SearchViewStyle" parent="Widget.AppCompat.SearchView">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/gray_text</item>
    </style>

</resources>